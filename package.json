{
  "name": "selfreview",
  "version": "0.1.0",
  "description": "Senior-reviewer pass for your PR before you click submit — powered by Kimi K2.6 on NVIDIA NIM",
  "type": "module",
  "bin": {
    "selfreview": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
"scripts": {
  "build": "tsc",
  "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
  "dev": "node --import tsx/esm src/index.ts",
  "start": "node dist/index.js",
  "typecheck": "tsc --noEmit",
  "format": "prettier --write src",
  "prepublishOnly": "npm run build"
},

  "keywords": ["git", "code-review", "ai", "security", "cli", "nvidia-nim", "kimi"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "openai": "^4.47.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
